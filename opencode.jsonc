{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "sonarqube": {
      "type": "remote",
      "url": "https://api.sonarcloud.io/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:SONARQUBE_TOKEN}",
        "SONARQUBE_ORG": "foosball-tracker",
        "SONARQUBE_PROJECT_KEY": "foosball-tracker_foosball-tracker",
        "SONARQUBE_READ_ONLY": "true",
      },
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=eucjxbcicejyinubzgwh&features=docs%2Cdatabase%2Cdebugging%2Cdevelopment%2Cfunctions%2Cbranching%2Cstorage",
      "enabled": true,
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
    },
    "playwright": {
      "type": "local",
      "enabled": true,
      "command": ["node", ".codex/playwright-mcp-launcher.mjs"],
    },
    "context7": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
    },
  },
}
